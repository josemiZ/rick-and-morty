# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Android Profiling
*.hprof

# Keystore files — uncomment if you do not want to check in your keystore
# *.jks
# *.keystore

# External native build folder generated in Android Studio 2.2+
.externalNativeBuild/
.cxx/

# Google Services (e.g. APIs or Firebase) — uncomment if you add it
# google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# ─────────────────────────────────────────────────────────────────────────────
# IntelliJ IDEA / Android Studio
# Whitelist team-shared settings under .idea/ via the bang pattern
# ─────────────────────────────────────────────────────────────────────────────

*.iml
*.ipr
*.iws
.idea/
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/icon.png

# JetBrains AI / Copilot caches
.aiassistant/
.copilot/

# AI agent playbooks / skill files (local-only; not for public repo)
.ai/

# ─────────────────────────────────────────────────────────────────────────────
# Kotlin
# ─────────────────────────────────────────────────────────────────────────────

.kotlin/
*.knm

